# Tesserix Home Environment Variables

# Development mode - Set to true to bypass authentication for local development
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# BFF (Backend for Frontend) URL for authentication
BFF_BASE_URL=http://localhost:8080

# Allowed CORS origin for API routes
NEXT_PUBLIC_ALLOWED_ORIGIN=http://localhost:3002

# Tenant Onboarding Service (content management)
ONBOARDING_SERVICE_URL=http://localhost:4201
ONBOARDING_ADMIN_API_KEY=your-admin-key-here
NEXT_PUBLIC_ONBOARDING_SITE_URL=http://localhost:4201

# HomeChef / Fe3dr admin — the admin section calls the HomeChef Go /admin/* API
# (signed as a trusted BFF; see lib/api/homechef-admin.ts). No direct DB.
# HOMECHEF_API_URL: base URL of the HomeChef Go API (in-cluster preferred).
HOMECHEF_API_URL=http://homechef-api.homechef.svc.cluster.local
# HOMECHEF_BFF_HMAC_KEY: base64 — the SAME shared HMAC secret the HomeChef Go API
# uses (BFF_INTERNAL_HMAC_KEY / GCP prod-homechef-bff-internal-hmac-key).
HOMECHEF_BFF_HMAC_KEY=base64-encoded-shared-hmac-key

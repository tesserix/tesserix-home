# PROD gateway — the app talks only to tesserix-home; it signs to the Go admin API.
# (Confirm the exact prod host; cookie domain is .tesserix.app.)
EXPO_PUBLIC_API_BASE=https://home.tesserix.app

# Google OAuth client ids for native sign-in (from the GCP/Firebase console for
# the app.tesserix.admin bundle). Their client ids must be in GOOGLE_MOBILE_CLIENT_IDS
# on the tesserix-home backend so the id_token audience is accepted.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Local dev only — leave OFF for prod (login is Google → allowlist).
EXPO_PUBLIC_DEV_AUTH_BYPASS=false
